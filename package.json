{
  "name": "gutu-lib-ai-mcp",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/ai-mcp build",
    "typecheck": "bun run --cwd framework/libraries/ai-mcp typecheck",
    "lint": "bun run --cwd framework/libraries/ai-mcp lint",
    "test": "bun run --cwd framework/libraries/ai-mcp test",
    "test:unit": "bun run --cwd framework/libraries/ai-mcp test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
